# Robot Marketing bot secrets — copy to .env and fill in. chmod 600 .env
# Voice (speech-to-text) only:
OPENAI_API_KEY=sk-...

# Text parsing (Claude Opus 4.8):
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from BotFather:
TELEGRAM_BOT_TOKEN=123456:ABC...

# Optional overrides:
# WEB_PORT=8080
# WEB_PASSWORD=robot1234
# MAX_EMPLOYEES=3
